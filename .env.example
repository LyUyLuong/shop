APP_HOST_PORT=8081
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=prod
SCHEDULING_POOL_SIZE=3

POSTGRES_HOST_PORT=5433
POSTGRES_DB=shop_db
POSTGRES_USER=shop_user
POSTGRES_PASSWORD=shop_password

DB_URL=jdbc:postgresql://postgres:5432/shop_db
DB_USERNAME=shop_user
DB_PASSWORD=shop_password

APP_PUBLIC_API_URL=http://localhost:8081
CORS_ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET=change-this-to-at-least-32-bytes-long-for-local-docker

AWS_REGION=ap-southeast-1
# Local Docker only, when S3/SQS must be tested from the app container.
# Leave blank for DB-only Docker runs and for EC2 IAM Role deployments.
# Put real values only in ignored .env, never in this example file.
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_BUCKET=your-shop-product-images-bucket
S3_PRODUCT_IMAGE_PREFIX=products
S3_PUBLIC_BASE_URL=

ORDER_EXPIRY_ENABLED=false
ORDER_EXPIRY_BATCH_SIZE=20
ORDER_EXPIRY_INITIAL_DELAY_MS=60000
ORDER_EXPIRY_FIXED_DELAY_MS=30000

ORDER_EVENTS_QUEUE_URL=
OUTBOX_PUBLISHER_ENABLED=false
OUTBOX_MAX_BATCH_SIZE=10
OUTBOX_MAX_RETRY_COUNT=5
OUTBOX_FIXED_DELAY_MS=10000

NOTIFICATION_CONSUMER_ENABLED=false
NOTIFICATION_CONSUMER_MAX_MESSAGES=10
NOTIFICATION_CONSUMER_WAIT_TIME_SECONDS=10
NOTIFICATION_CONSUMER_VISIBILITY_TIMEOUT_SECONDS=30
NOTIFICATION_CONSUMER_FIXED_DELAY_MS=10000
